{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadIngestionBucket",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::{{ING}}",
        "arn:aws:s3:::{{ING}}/*"
      ]
    },
    {
      "Sid": "WriteAppBucket",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::{{APP}}",
        "arn:aws:s3:::{{APP}}/*"
      ]
    }
  ]
}
