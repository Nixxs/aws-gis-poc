{
  "jobDefinitionName": "gis-poc-job",
  "type": "container",
  "platformCapabilities": ["FARGATE"],
  "containerProperties": {
    "image": "{{REPO}}:latest",
    "executionRoleArn": "arn:aws:iam::{{ACCT}}:role/gisPocBatchExecutionRole",
    "jobRoleArn": "arn:aws:iam::{{ACCT}}:role/gisPocBatchJobRole",
    "networkConfiguration": { "assignPublicIp": "ENABLED" },
    "resourceRequirements": [
      { "type": "VCPU", "value": "0.5" },
      { "type": "MEMORY", "value": "1024" }
    ],
    "environment": [
      { "name": "INGESTION_BUCKET", "value": "{{ING}}" },
      { "name": "APP_BUCKET", "value": "{{APP}}"},
      { "name": "SOURCE_PREFIX", "value": "" },
      { "name": "DEST_PREFIX", "value": "raw/" }
    ]
  }
}
